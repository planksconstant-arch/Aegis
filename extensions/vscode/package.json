{
  "name": "aegis-vscode",
  "displayName": "Aegis Agent",
  "description": "Local RL-Powered AI Coding Assistant",
  "version": "0.1.0",
  "publisher": "planksconstant",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Machine Learning",
    "Other"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "aegis.startSession",
        "title": "Aegis: Connect to Local Agent"
      },
      {
        "command": "aegis.generateFix",
        "title": "Aegis: Generate Fix (LLM + RL)"
      },
      {
        "command": "aegis.acceptSuggestion",
        "title": "Aegis: Accept Suggestion"
      },
      {
        "command": "aegis.rejectSuggestion",
        "title": "Aegis: Reject Suggestion"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "aegis.generateFix",
          "group": "navigation"
        },
        {
          "command": "aegis.startSession",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/mocha": "^10.0.1",
    "@types/node": "18.x",
    "@typescript-eslint/eslint-plugin": "^5.59.1",
    "@typescript-eslint/parser": "^5.59.1",
    "eslint": "^8.39.0",
    "glob": "^8.1.0",
    "mocha": "^10.2.0",
    "typescript": "^5.0.4",
    "@vscode/test-electron": "^2.3.0"
  },
  "dependencies": {
    "axios": "^1.4.0"
  }
}
